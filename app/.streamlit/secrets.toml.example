# ============================================================
# CONTOH FILE secrets.toml
# 1. Copy file ini, rename jadi secrets.toml (tanpa .example)
# 2. Isi sesuai langkah di README.md
# 3. JANGAN commit secrets.toml ke git!
# ============================================================

# --- OPSI A: Public Sheet (paling mudah, tapi readonly publik) ---
# Cukup isi spreadsheet URL-nya, sheet harus di-share "Anyone with link can view"
# [connections.gsheets]
# spreadsheet = "https://docs.google.com/spreadsheets/d/XXXXXXXXXXXX/edit"

# --- OPSI B: Service Account (RECOMMENDED untuk read+write) ---
[connections.gsheets]
spreadsheet = "https://docs.google.com/spreadsheets/d/GANTI_DENGAN_ID_SHEET_LO/edit"
worksheet  = "DPPH"  # default worksheet (opsional)

type = "service_account"
project_id = "your-project-id"
private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
private_key = "-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"
client_email = "streamlit-bot@your-project-id.iam.gserviceaccount.com"
client_id = "1234567890"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/streamlit-bot%40your-project-id.iam.gserviceaccount.com"

# ============================================================
# AUTH SEDERHANA (opsional)
# Aktifkan kalau mau gate write operation pakai passcode.
# Kalau section ini dihapus / enabled=false -> auth dimatikan,
# semua bisa input data.
# ============================================================
[auth]
enabled = true
passcode = "ganti-passcode-rahasia-lo"
label    = "Peneliti"
