# Auto-detect text files & normalize line endings (LF di repo, CRLF di Windows)
* text=auto eol=lf

# Source code: explicit LF
*.py     text eol=lf
*.md     text eol=lf
*.toml   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.txt    text eol=lf

# Binary files: jangan diutak-atik
*.xlsx   binary
*.xls    binary
*.pdf    binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.zip    binary
